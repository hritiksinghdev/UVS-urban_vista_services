generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QueryStatus {
  NEW
  SEEN
  REPLIED
}

enum OTPType {
  EMAIL_VERIFY
  PHONE_VERIFY
  PASSWORD_RESET
}

model User {
  id               String    @id @default(cuid())
  firebaseUid      String    @unique
  email            String    @unique
  name             String
  phone            String?
  phoneVerified    Boolean   @default(false)
  businessType     String?
  emailVerified    Boolean   @default(false)
  role             Role      @default(USER)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  orders           Order[]
  contactQueries   ContactQuery[]
  otpVerifications OTPVerification[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  serviceName String
  description String?
  budget      String?
  timeline    String?
  status      OrderStatus @default(PENDING)
  notes       String?
  amount      Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ContactQuery {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  name        String
  email       String
  phone       String?
  business    String?
  message     String
  status      QueryStatus @default(NEW)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OTPVerification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  email     String?
  phone     String?
  otpHash   String
  type      OTPType
  expiresAt DateTime
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
